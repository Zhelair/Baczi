# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── DeepSeek AI ────────────────────────────────────────────────────────────
# Get your key from https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# ─── JWT signing secret ──────────────────────────────────────────────────────
# Any random string ≥32 chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# ─── Passphrases ─────────────────────────────────────────────────────────────
# Comma-separated list of passphrases for each tier.
# These stay SECRET on Vercel — never commit this file with real values.
#
# free    — 500 tokens/month
# pro     — 2 000 tokens/month
# max     — 10 000 tokens/month
# admin   — unlimited + admin panel
FREE_PASSPHRASES=autumn-wind,morning-dew
PRO_PASSPHRASES=golden-dragon,jade-mountain
MAX_PASSPHRASES=celestial-tiger,phoenix-rising
ADMIN_PASSPHRASES=my-secret-admin-phrase
