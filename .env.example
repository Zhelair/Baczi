# Copy this to .env.local for local development
# NEVER commit .env.local to git

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-key-here

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-random-long-secret-here

# Passphrases per tier (mom shares these with customers)
FREE_PASSPHRASE=free-trial-word
PRO_PASSPHRASE=pro-access-word
MAX_PASSPHRASE=vip-access-word

# Vercel KV (auto-populated by Vercel when KV store is linked)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Supabase (also used by the local knowledge scraper)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
